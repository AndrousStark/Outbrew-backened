# =============================================================================
# Outbrew Backend — VPS Environment Variables (Neon PostgreSQL)
# =============================================================================
# cp .env.vps.example .env && nano .env
# NEVER commit .env — it's in .gitignore
# =============================================================================

# Application
PROJECT_NAME=Outbrew API
ENVIRONMENT=production
DEBUG=false
BASE_URL=https://api.outbrew.metaminds.store

# CORS
CORS_ORIGINS=https://metaminds.store,https://www.metaminds.store

# Database — Neon PostgreSQL (pooled connection)
# Get this from Neon dashboard → Connection Details → Pooled
DATABASE_URL=postgresql://neondb_owner:YOUR_PASSWORD@ep-xxx-pooler.region.neon.tech/neondb?sslmode=require

# Security (generate each with: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_SECRET_KEY_HERE
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_HERE
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis — Uses existing unjynx-valkey on VPS, database 2
# Set by docker-compose.vps.yml, leave empty here
REDIS_ENABLED=true
REDIS_URL=

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# User Emails (set via API registration, or fill here)
PRAGYA_EMAIL=
PRAGYA_PASSWORD=
ANIRUDDH_EMAIL=
ANIRUDDH_PASSWORD=

# AI (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Storage
STORAGE_BASE_PATH=storage
EXPORTS_DIR=exports
MAX_FILE_SIZE_MB=25
MAX_STORAGE_QUOTA_MB=500
