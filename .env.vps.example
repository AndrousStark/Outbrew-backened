# =============================================================================
# Outbrew Backend — VPS Environment Variables (Hetzner cx23)
# =============================================================================
# Shares PostgreSQL and Redis with existing Unjynx containers.
# Copy to .env:  cp .env.vps.example .env && nano .env
# =============================================================================

# Application
PROJECT_NAME=Outbrew API
ENVIRONMENT=production
DEBUG=false
BASE_URL=https://api.outbrew.metaminds.store

# CORS
CORS_ORIGINS=https://metaminds.store,https://www.metaminds.store

# Database — Uses existing unjynx-postgres, separate database
# deploy-vps.sh db-setup creates this user and database automatically
POSTGRES_USER=outbrew_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD
POSTGRES_DB=outbrew
# DATABASE_URL is set by docker-compose.vps.yml, leave empty
DATABASE_URL=

# Security (generate: openssl rand -hex 32)
SECRET_KEY=CHANGE_ME_SECRET_KEY_HERE
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_HERE
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis — Uses existing unjynx-valkey, database 2 (Unjynx uses db 0)
REDIS_PASSWORD=
REDIS_ENABLED=true

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# User Emails (set via API registration, or fill here)
PRAGYA_EMAIL=
PRAGYA_PASSWORD=
ANIRUDDH_EMAIL=
ANIRUDDH_PASSWORD=

# AI (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Storage
STORAGE_BASE_PATH=storage
EXPORTS_DIR=exports
MAX_FILE_SIZE_MB=25
MAX_STORAGE_QUOTA_MB=500
