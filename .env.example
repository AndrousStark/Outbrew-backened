# =============================================================
# Outbrew - Environment Configuration
# Copy this file to .env and fill in your values
# =============================================================

# Application
ENVIRONMENT=development
DEBUG=false
BASE_URL=http://localhost:8000

# CORS
CORS_ORIGINS=http://localhost:3000

# Database — Option 1: Neon / Railway / any hosted PostgreSQL (recommended)
# DATABASE_URL=postgresql://user:pass@ep-xyz-123.us-east-2.aws.neon.tech/neondb?sslmode=require

# Database — Option 2: Local PostgreSQL (individual vars)
POSTGRES_SERVER=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=outbrew
POSTGRES_PORT=5432

# Authentication (REQUIRED)
SECRET_KEY=generate-a-strong-random-key-here
ENCRYPTION_KEY=generate-a-separate-32-byte-key-here
WEBHOOK_SECRET=generate-a-webhook-secret-here

# Token Expiry
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Allowed redirect domains for click tracking (comma-separated)
ALLOWED_REDIRECT_DOMAINS=yourdomain.com

# Redis (optional, in-memory fallback for dev)
REDIS_URL=redis://localhost:6379/0
REDIS_ENABLED=false

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# AI Services (optional)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Enrichment APIs (optional, server-side only)
APOLLO_API_KEY=
HUNTER_API_KEY=
CLEARBIT_API_KEY=
PROXYCURL_API_KEY=
BUILTWITH_API_KEY=

# Storage
STORAGE_BASE_PATH=storage
MAX_FILE_SIZE_MB=25
MAX_STORAGE_QUOTA_MB=500
