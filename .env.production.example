# =============================================================================
# Outbrew Backend — Production Environment Variables
# =============================================================================
# Copy this file to .env on your Hetzner VPS:
#   cp .env.production.example .env
#   nano .env  # Fill in all values
#
# IMPORTANT: Never commit this file with real values.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
PROJECT_NAME=Outbrew API
ENVIRONMENT=production
DEBUG=false
BASE_URL=https://YOUR_DOMAIN

# ---------------------------------------------------------------------------
# CORS — Allowed frontend origins (comma-separated)
# ---------------------------------------------------------------------------
CORS_ORIGINS=https://metaminds.store,https://www.metaminds.store

# ---------------------------------------------------------------------------
# Database (PostgreSQL — used by both app and docker-compose)
# ---------------------------------------------------------------------------
POSTGRES_USER=outbrew_user
POSTGRES_PASSWORD=CHANGE_ME_STRONG_DB_PASSWORD_HERE
POSTGRES_DB=outbrew
POSTGRES_PORT=5432
# DATABASE_URL is built automatically by docker-compose. Leave empty here.
DATABASE_URL=

# ---------------------------------------------------------------------------
# Security (REQUIRED — generate with: openssl rand -hex 32)
# ---------------------------------------------------------------------------
SECRET_KEY=CHANGE_ME_SECRET_KEY_HERE
ENCRYPTION_KEY=CHANGE_ME_ENCRYPTION_KEY_HERE
WEBHOOK_SECRET=CHANGE_ME_WEBHOOK_SECRET_HERE
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ---------------------------------------------------------------------------
# Allowed redirect domains for click tracking
# ---------------------------------------------------------------------------
ALLOWED_REDIRECT_DOMAINS=metaminds.store

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_PASSWORD=CHANGE_ME_STRONG_REDIS_PASSWORD
REDIS_ENABLED=true
# REDIS_URL is built by docker-compose. Leave empty here.
REDIS_URL=

# ---------------------------------------------------------------------------
# SMTP (Gmail App Password recommended)
# ---------------------------------------------------------------------------
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# ---------------------------------------------------------------------------
# User Email Accounts (set per user, or leave empty for self-registration)
# ---------------------------------------------------------------------------
PRAGYA_EMAIL=
PRAGYA_PASSWORD=
PRAGYA_RESUME_PATH=

ANIRUDDH_EMAIL=
ANIRUDDH_PASSWORD=
ANIRUDDH_RESUME_PATH=

# ---------------------------------------------------------------------------
# AI Services (optional)
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---------------------------------------------------------------------------
# Enrichment APIs (optional — server-side only, never exposed to frontend)
# ---------------------------------------------------------------------------
APOLLO_API_KEY=
HUNTER_API_KEY=
CLEARBIT_API_KEY=
PROXYCURL_API_KEY=
BUILTWITH_API_KEY=

# ---------------------------------------------------------------------------
# Storage
# ---------------------------------------------------------------------------
STORAGE_BASE_PATH=storage
EXPORTS_DIR=exports
MAX_FILE_SIZE_MB=25
MAX_STORAGE_QUOTA_MB=1000

# ---------------------------------------------------------------------------
# Gunicorn / Performance (used by docker-compose environment)
# ---------------------------------------------------------------------------
API_WORKERS=4
